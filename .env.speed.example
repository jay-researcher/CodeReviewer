# CodeReviewer Speed Profile
# Use this when you want Codex Fast / priority service tier while preserving detailed review depth.

LLM_PROVIDER=auto
LLM_NETWORK_MODE=direct
LLM_CODEX_MODEL=gpt-5.5
LLM_SPEED=fast
# Speed is independent from reasoning effort. Use high or xhigh for release review.
LLM_REASONING_EFFORT=high
LLM_CODEX_TIMEOUT_SECONDS=300
LLM_TIMEOUT_SECONDS=180
LLM_CODEX_DISABLE_FEATURE=shell_snapshot

# Keep detailed and elaborated output.
LLM_MAX_TOKENS=6000
LLM_MAX_DIFF_CHARS=60000
MAX_FINDINGS=500
REPORT_DETAIL_LEVEL=detailed
REPORT_LANGUAGE=zh-CN
REVIEW_RESUME=1

# Preserve local project context for deep review.
PROJECT_CONTEXT_MAX_CHARS=80000
PROJECT_CONTEXT_MAX_TREE_FILES=500
PROJECT_CONTEXT_MAX_FILE_CHARS=12000

# Keep GIT_VERSION deep correctness checks.
WEB_BUILD_CONTEXT_MAX_CHARS=20000
WEB_BUILD_REFERENCE_MAX_CHARS=10000
GIT_VERSION_DEEP_REVIEW=1
GIT_VERSION_COMPARE_PREVIOUS=1
GIT_VERSION_SOURCE_REVIEW_MAX_REPOS=12
GIT_VERSION_SOURCE_REVIEW_MAX_FILES_PER_REPO=60
GIT_VERSION_SOURCE_DIFF_CONTEXT_MAX_CHARS=100000

# Use rule-based only for the fastest smoke check:
# LLM_PROVIDER=rule-based
