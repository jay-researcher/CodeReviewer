# CodeReviewer environment template
#
# Application policy defaults now live in config.yml under the top-level `app:`
# section. Keep this file for deployment environment, credentials, host-specific
# paths, network posture, and executable locations only.

# Web runtime
WEB_HOST=127.0.0.1
WEB_PORT=8765
WEB_TRUST_PROXY=0
WEB_IP_WHITELIST=127.0.0.1
WEB_IP_WHITELIST_FILE=data/web_ip_whitelist.txt
WEB_IP_WHITELIST_INCLUDE_LOOPBACK=1
WEB_AUTH_PRUNE_USERS=1

# GitLab access
# Required scopes: api, read_api, read_repository
GITLAB_URL=https://gitlab.tx-tech.com
GITLAB_TOKEN=glpat-REPLACE_WITH_YOUR_TOKEN
GITLAB_USE_CURL_FIRST=1

# Jira access
JIRA_URL=https://tx-tech.atlassian.net
JIRA_USERNAME=your-email@company.com
JIRA_TOKEN=REPLACE_WITH_YOUR_JIRA_TOKEN
JIRA_SEARCH_API=auto
JIRA_GITLAB_APPLICATION_TYPE=GitLab

# LLM provider credentials / runtime binaries
CODEX_CLI_PATH=
LLM_CODEX_DISABLE_FEATURE=shell_snapshot
# Optional override; default comes from config.yml app.llm.cc_switch_provider.
# LLM_CC_SWITCH_PROVIDER=Claude code opus
DEEPSEEK_API_KEY=REPLACE_WITH_DEEPSEEK_TOKEN
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
CODEBASE_MEMORY_COMMAND=
# Optional remote Linux CLI mode. Do not set CODEBASE_MEMORY_COMMAND when enabled.
CODEBASE_MEMORY_SSH_HOST=
CODEBASE_MEMORY_SSH_PORT=22
CODEBASE_MEMORY_SSH_USER=
CODEBASE_MEMORY_SSH_CONFIG=
CODEBASE_MEMORY_SSH_KEY_FILE=
CODEBASE_MEMORY_SSH_STRICT_HOST_KEY=1
CODEBASE_MEMORY_REMOTE_COMMAND=/usr/local/bin/codebase-memory-mcp
CODEBASE_MEMORY_REMOTE_SOURCE_ROOT=/var/lib/codebase-memory-mcp/sources
CODEBASE_MEMORY_REMOTE_STATE_ROOT=/var/lib/codebase-memory-mcp/codereviewer-state

# Teams integration
TEAMS_BOT_WEBHOOK_URL=
TEAMS_BOT_CA_BUNDLE=

# Deployment paths
GIT_TOOLS_CONFIG=D:\TTL\vibe-coding\CodeReviewer\config.yml
REPORT_OUTPUT_BASE_DIR=D:\TTL\code-review
CHINA_WORK_CALENDAR_FILE=D:\TTL\vibe-coding\CodeReviewer\data\china-mainland-work-calendar.json
REPORT_OUTPUT_DIR=
JIRA_PRD_DATA_DIR=D:\TTL\jira-prd\data
JIRA_PRD_FETCH_SCRIPT=D:\TTL\jira-prd\fetch_jira.py
WEB_BUILD_TOOLS_DIR=D:\TTL\vibe-coding\web-build-tools
CODE_REVIEW_REQUIREMENT_FILE=D:\TTL\code-review\code_review_requirement.md
GITNEXUS_STORAGE_PATH=data/gitnexus
GITNEXUS_INDEX_FILE=review_index.jsonl

# Host/runtime timeouts. Business defaults belong in config.yml app:.
CODEX_CHECK_TIMEOUT_SECONDS=180
LLM_CODEX_TIMEOUT_SECONDS=300
LLM_TIMEOUT_SECONDS=180
LLM_MAX_RETRIES=3
REPOSITORY_FETCH_TIMEOUT_SECONDS=300
REPOSITORY_CLONE_TIMEOUT_SECONDS=900
CODEBASE_MEMORY_TIMEOUT_SECONDS=120
CODEBASE_MEMORY_MAX_REPOSITORY_FILES=50000
CODEBASE_MEMORY_QUERY_TIMEOUT_SECONDS=60
CODEBASE_MEMORY_CHECKOUT_TIMEOUT_SECONDS=420

# Optional runtime-only overrides for troubleshooting.
# Prefer config.yml app: for persistent defaults.
# CODE_REVIEW_OVERRIDE_REPORT_MIN_SEVERITY=High
# CODE_REVIEW_OVERRIDE_SPRINT_MR_STATE=opened,merged
# CODE_REVIEW_OVERRIDE_LLM_SPEED=fast
